#!/usr/bin/env bash
set -euo pipefail

# agent-sudo — CLI queue entry for agent-sudo privilege approval gateway.
#
# Usage: agent-sudo --reason "<reason>" -- <command...>
#
# Appends a command entry to ~/.cache/agent-sudo/queue.json.
# The GUI (`agent-sudo-flush`) reads this file for human approval.

QUEUE_FILE="$HOME/.cache/agent-sudo/queue.json"
QUEUE_DIR="$HOME/.cache/agent-sudo"

# ── Parse arguments ────────────────────────────────────────────────────────

REASON=""
COMMAND=()
MODE=""
for arg in "$@"; do
    case "$arg" in
        --reason) MODE="reason" ;;
        --)       MODE="cmd"    ;;
        *)
            case "$MODE" in
                reason) REASON="$arg"; MODE="" ;;
                cmd)    COMMAND+=("$arg") ;;
            esac
            ;;
    esac
done

if [ -z "$REASON" ]; then
    echo "ERROR: --reason is required" >&2
    exit 127
fi
if [ ${#COMMAND[@]} -eq 0 ]; then
    echo "ERROR: no command provided (use -- before command)" >&2
    exit 127
fi

# ── Ensure cache directory exists ───────────────────────────────────────────

mkdir -p "$QUEUE_DIR"
chmod 700 "$QUEUE_DIR"

# ── Compute next id ─────────────────────────────────────────────────────────

if [ -f "$QUEUE_FILE" ]; then
    NEXT_ID=$(jq '[.items[]?.id // 0] | max + 1' "$QUEUE_FILE" 2>/dev/null)
    NEXT_ID=${NEXT_ID:-1}
else
    NEXT_ID=1
fi

# ── Build new item ──────────────────────────────────────────────────────────

CMD_STR=$(printf '%s ' "${COMMAND[@]}" | sed 's/ $//')

ITEM=$(jq -n \
    --argjson id "$NEXT_ID" \
    --arg reason "$REASON" \
    --arg command "$CMD_STR" \
    --arg cwd "$PWD" \
    '{id: $id, reason: $reason, command: $command, cwd: $cwd}')

# ── Append to queue ─────────────────────────────────────────────────────────

if [ -f "$QUEUE_FILE" ] && [ -s "$QUEUE_FILE" ]; then
    jq --argjson item "$ITEM" \
       '.items += [$item] | .version = 1' \
       "$QUEUE_FILE" > "${QUEUE_FILE}.tmp"
    mv "${QUEUE_FILE}.tmp" "$QUEUE_FILE"
else
    jq -n --argjson item "$ITEM" \
       '{version: 1, items: [$item]}' > "$QUEUE_FILE"
fi

chmod 600 "$QUEUE_FILE"
